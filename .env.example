# --- Local (python app.py) ---
PORT=5000

# URL publique du site (obligatoire sur Vercel pour le favori)
# Ex. https://votre-projet.vercel.app ou https://infobox.votredomaine.com
INFOBOX_PUBLIC_URL=

# Sécurité API (optionnel — protège /api/scrape, /api/import, etc.)
# Le favori /assistant reste accessibles sans cette clé
INFOBOX_API_KEY=
FLASK_SECRET_KEY=

# Limite requêtes / minute / IP sur les API
INFOBOX_MAX_BODY=2097152
INFOBOX_RATE_LIMIT_PER_MIN=90

# BoxRec — uniquement pour collecte serveur (pas le favori)
BOXREC_USERNAME=
BOXREC_PASSWORD=
SCRAPE_DELAY_SECONDS=1.5
BOXREC_LOCATION=gb_15599
BOXREC_LEVEL_ID=gb
BOXREC_LOC_TXT=United Kingdom
BOXREC_SEX=m

# Enrichissement managers sans contact (scripts/enrich_sans_contact.py)
ENRICH_DELAY_SECONDS=2.5

# Supabase — scripts sync_managers_supabase.py, apply_migration_supabase.py
# (peut aussi être lu depuis boxing-center-bot/.env)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optionnel — migration SQL directe via PostgreSQL
SUPABASE_DB_URL=
